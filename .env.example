# Career Bot – Environment Configuration
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Your OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Model to use for agents (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Vector Store ──────────────────────────────────────────────────────────────
# Directory where ChromaDB persists embeddings (default: .chroma)
# CHROMA_PERSIST_DIR=.chroma

# Collection name for personal documents (default: career_docs)
# CHROMA_COLLECTION=career_docs

# ── Paths ─────────────────────────────────────────────────────────────────────
# Directory to scan for personal documents (default: docs/)
# DOCS_DIR=docs

# Directory where generated resumes are saved (default: output/)
# OUTPUT_DIR=output
